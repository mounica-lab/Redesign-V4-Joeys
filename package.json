{
  "name": "joeys-meal-planning",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"npm --prefix server run dev\"",
    "dev:web": "vite",
    "dev:api": "npm --prefix server run dev",
    "build": "vite build",
    "preview": "vite preview",
    "install:all": "npm install && npm --prefix server install"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.3.2"
  }
}
